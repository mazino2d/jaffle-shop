# Target environment: dev | prod | cloud
DBT_TARGET=dev

# dev: local DuckDB for development
DUCKDB_DEV_PATH=/absolute/path/to/jaffle-shop/jaffle_shop_dev.duckdb

# prod: local DuckDB for production dataset
DUCKDB_PROD_PATH=/absolute/path/to/jaffle-shop/jaffle_shop_prod.duckdb

# cloud: MotherDuck — only required when DBT_TARGET=cloud
# MOTHERDUCK_TOKEN=your_motherduck_token_here
